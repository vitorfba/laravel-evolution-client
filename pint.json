{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": false,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "not_operator_with_successor_space": true,
        "trailing_comma_in_multiline": true,
        "concat_space": {
            "spacing": "one"
        },
        "fully_qualified_strict_types": true,
        "phpdoc_align": {
            "align": "left"
        }
    }
}
