{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "agent": {
    "package-writer": {
      "description": "Implement/modify Resources, Models, Services and their tests.",
      "mode": "subagent",
      "prompt": "{file:./.opencode/agent/package-writer.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "edit": true,
        "write": true,
        "bash": true
      }
    },
    "package-reviewer": {
      "description": "Review a diff for conventions, API correctness and test coverage. Read-only.",
      "mode": "subagent",
      "prompt": "{file:./.opencode/agent/package-reviewer.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "bash": true,
        "edit": false,
        "write": false
      }
    }
  }
}
